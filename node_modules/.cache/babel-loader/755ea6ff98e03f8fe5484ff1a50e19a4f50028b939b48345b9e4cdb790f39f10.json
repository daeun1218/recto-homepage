{"ast":null,"code":"import{createContext,useContext,useState}from'react';import{jsx as _jsx}from\"react/jsx-runtime\";const CartContext=/*#__PURE__*/createContext();export function CartProvider(_ref){let{children}=_ref;const[cartItems,setCartItems]=useState([]);const addToCart=item=>{setCartItems(prev=>[...prev,item]);};const removeFromCart=index=>{setCartItems(prev=>prev.filter((_,i)=>i!==index));};const updateQuantity=(index,newQty)=>{if(newQty<1)return;setCartItems(prev=>prev.map((item,i)=>i===index?{...item,quantity:newQty,price:item.price/item.quantity*newQty}:item));};const cartCount=cartItems.reduce((sum,item)=>sum+item.quantity,0);return/*#__PURE__*/_jsx(CartContext.Provider,{value:{cartItems,cartCount,addToCart,removeFromCart,updateQuantity},children:children});}export function useCart(){return useContext(CartContext);}","map":{"version":3,"names":["createContext","useContext","useState","jsx","_jsx","CartContext","CartProvider","_ref","children","cartItems","setCartItems","addToCart","item","prev","removeFromCart","index","filter","_","i","updateQuantity","newQty","map","quantity","price","cartCount","reduce","sum","Provider","value","useCart"],"sources":["/Users/ida-eun/Desktop/recto-homepage/src/context/CartContext.js"],"sourcesContent":["import { createContext, useContext, useState } from 'react';\n\nconst CartContext = createContext();\n\nexport function CartProvider({ children }) {\n  const [cartItems, setCartItems] = useState([]);\n\n  const addToCart = (item) => {\n    setCartItems((prev) => [...prev, item]);\n  };\n\n  const removeFromCart = (index) => {\n    setCartItems((prev) => prev.filter((_, i) => i !== index));\n  };\n\n  const updateQuantity = (index, newQty) => {\n    if (newQty < 1) return;\n    setCartItems((prev) =>\n      prev.map((item, i) =>\n        i === index\n          ? { ...item, quantity: newQty, price: (item.price / item.quantity) * newQty }\n          : item\n      )\n    );\n  };\n\n  const cartCount = cartItems.reduce((sum, item) => sum + item.quantity, 0);\n\n  return (\n    <CartContext.Provider value={{ cartItems, cartCount, addToCart, removeFromCart, updateQuantity }}>\n      {children}\n    </CartContext.Provider>\n  );\n}\n\nexport function useCart() {\n  return useContext(CartContext);\n}\n"],"mappings":"AAAA,OAASA,aAAa,CAAEC,UAAU,CAAEC,QAAQ,KAAQ,OAAO,CAAC,OAAAC,GAAA,IAAAC,IAAA,yBAE5D,KAAM,CAAAC,WAAW,cAAGL,aAAa,CAAC,CAAC,CAEnC,MAAO,SAAS,CAAAM,YAAYA,CAAAC,IAAA,CAAe,IAAd,CAAEC,QAAS,CAAC,CAAAD,IAAA,CACvC,KAAM,CAACE,SAAS,CAAEC,YAAY,CAAC,CAAGR,QAAQ,CAAC,EAAE,CAAC,CAE9C,KAAM,CAAAS,SAAS,CAAIC,IAAI,EAAK,CAC1BF,YAAY,CAAEG,IAAI,EAAK,CAAC,GAAGA,IAAI,CAAED,IAAI,CAAC,CAAC,CACzC,CAAC,CAED,KAAM,CAAAE,cAAc,CAAIC,KAAK,EAAK,CAChCL,YAAY,CAAEG,IAAI,EAAKA,IAAI,CAACG,MAAM,CAAC,CAACC,CAAC,CAAEC,CAAC,GAAKA,CAAC,GAAKH,KAAK,CAAC,CAAC,CAC5D,CAAC,CAED,KAAM,CAAAI,cAAc,CAAGA,CAACJ,KAAK,CAAEK,MAAM,GAAK,CACxC,GAAIA,MAAM,CAAG,CAAC,CAAE,OAChBV,YAAY,CAAEG,IAAI,EAChBA,IAAI,CAACQ,GAAG,CAAC,CAACT,IAAI,CAAEM,CAAC,GACfA,CAAC,GAAKH,KAAK,CACP,CAAE,GAAGH,IAAI,CAAEU,QAAQ,CAAEF,MAAM,CAAEG,KAAK,CAAGX,IAAI,CAACW,KAAK,CAAGX,IAAI,CAACU,QAAQ,CAAIF,MAAO,CAAC,CAC3ER,IACN,CACF,CAAC,CACH,CAAC,CAED,KAAM,CAAAY,SAAS,CAAGf,SAAS,CAACgB,MAAM,CAAC,CAACC,GAAG,CAAEd,IAAI,GAAKc,GAAG,CAAGd,IAAI,CAACU,QAAQ,CAAE,CAAC,CAAC,CAEzE,mBACElB,IAAA,CAACC,WAAW,CAACsB,QAAQ,EAACC,KAAK,CAAE,CAAEnB,SAAS,CAAEe,SAAS,CAAEb,SAAS,CAAEG,cAAc,CAAEK,cAAe,CAAE,CAAAX,QAAA,CAC9FA,QAAQ,CACW,CAAC,CAE3B,CAEA,MAAO,SAAS,CAAAqB,OAAOA,CAAA,CAAG,CACxB,MAAO,CAAA5B,UAAU,CAACI,WAAW,CAAC,CAChC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}