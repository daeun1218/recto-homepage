{"ast":null,"code":"import{createContext,useContext,useState}from'react';import{jsx as _jsx}from\"react/jsx-runtime\";const CartContext=/*#__PURE__*/createContext();export function CartProvider(_ref){let{children}=_ref;const[cartItems,setCartItems]=useState([]);const addToCart=item=>{setCartItems(prev=>[...prev,item]);};const cartCount=cartItems.reduce((sum,item)=>sum+item.quantity,0);return/*#__PURE__*/_jsx(CartContext.Provider,{value:{cartItems,cartCount,addToCart},children:children});}export function useCart(){return useContext(CartContext);}","map":{"version":3,"names":["createContext","useContext","useState","jsx","_jsx","CartContext","CartProvider","_ref","children","cartItems","setCartItems","addToCart","item","prev","cartCount","reduce","sum","quantity","Provider","value","useCart"],"sources":["/Users/ida-eun/Desktop/recto-homepage/src/context/CartContext.js"],"sourcesContent":["import { createContext, useContext, useState } from 'react';\n\nconst CartContext = createContext();\n\nexport function CartProvider({ children }) {\n  const [cartItems, setCartItems] = useState([]);\n\n  const addToCart = (item) => {\n    setCartItems((prev) => [...prev, item]);\n  };\n\n  const cartCount = cartItems.reduce((sum, item) => sum + item.quantity, 0);\n\n  return (\n    <CartContext.Provider value={{ cartItems, cartCount, addToCart }}>\n      {children}\n    </CartContext.Provider>\n  );\n}\n\nexport function useCart() {\n  return useContext(CartContext);\n}\n"],"mappings":"AAAA,OAASA,aAAa,CAAEC,UAAU,CAAEC,QAAQ,KAAQ,OAAO,CAAC,OAAAC,GAAA,IAAAC,IAAA,yBAE5D,KAAM,CAAAC,WAAW,cAAGL,aAAa,CAAC,CAAC,CAEnC,MAAO,SAAS,CAAAM,YAAYA,CAAAC,IAAA,CAAe,IAAd,CAAEC,QAAS,CAAC,CAAAD,IAAA,CACvC,KAAM,CAACE,SAAS,CAAEC,YAAY,CAAC,CAAGR,QAAQ,CAAC,EAAE,CAAC,CAE9C,KAAM,CAAAS,SAAS,CAAIC,IAAI,EAAK,CAC1BF,YAAY,CAAEG,IAAI,EAAK,CAAC,GAAGA,IAAI,CAAED,IAAI,CAAC,CAAC,CACzC,CAAC,CAED,KAAM,CAAAE,SAAS,CAAGL,SAAS,CAACM,MAAM,CAAC,CAACC,GAAG,CAAEJ,IAAI,GAAKI,GAAG,CAAGJ,IAAI,CAACK,QAAQ,CAAE,CAAC,CAAC,CAEzE,mBACEb,IA